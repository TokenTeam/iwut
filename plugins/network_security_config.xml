<?xml version="1.0" encoding="utf-8"?>
<!-- 仅允许校园网相关域名使用明文 HTTP，其余流量强制 HTTPS -->
<network-security-config>
  <base-config cleartextTrafficPermitted="false">
    <trust-anchors>
      <certificates src="system" />
    </trust-anchors>
  </base-config>
  <domain-config cleartextTrafficPermitted="true">
    <!-- 校内系统 -->
    <domain includeSubdomains="true">whut.edu.cn</domain>
    <!-- 校园网认证探测与网关 -->
    <domain includeSubdomains="false">223.5.5.5</domain>
    <domain includeSubdomains="false">172.30.21.100</domain>
  </domain-config>
</network-security-config>
